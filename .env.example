# DATA_DIR: 제안서 PDF 폴더 경로 (config.py에서 기본값 설정됨)
# 다른 PC에서 실행 시 아래 줄의 주석을 해제하고 실제 경로로 변경하세요
# DATA_DIR=C:\Users\YourName\Downloads\제안서

# 로컬 LLM 설정 (OpenAI 호환)
LLM_BASE_URL=http://192.168.5.94:8001/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3-vl-2b-instruct

# 임베딩 제공자: openai / local
EMBEDDING_PROVIDER=openai

# 검색 모드
# - hybrid: 전체 청크 대상으로 dense+sparse 검색
# - hybrid_cluster: 가까운 클러스터만 먼저 고른 뒤 dense+sparse 검색
RETRIEVER_MODE=hybrid
DENSE_WEIGHT=0.85
SPARSE_WEIGHT=0.15
CLUSTER_N_CLUSTERS=24
CLUSTER_TOP_N=3
DOCUMENT_CLUSTER_N_CLUSTERS=6
DOCUMENT_CLUSTER_MIN_CLUSTER_SIZE=2
DOCUMENT_CLUSTER_MIN_SAMPLES=1
RETRIEVAL_FETCH_MULTIPLIER=4
MAX_CHUNKS_PER_FILE=2
OCR_SCORE_PENALTY=0.05
OCR_FOCUS_EXTRA_PENALTY=0.07

# OpenAI API Key (임베딩용)
OPENAI_API_KEY=your_openai_key_here

# 임베딩 모델
# - openai 권장: text-embedding-3-small
# - local 권장: BAAI/bge-m3
# EMBEDDING_MODEL=text-embedding-3-small

# OCR 설정 (스캔 PDF 처리용)
OCR_ENABLED=true
OCR_LANG=kor+eng
OCR_MIN_TEXT_CHARS=30

# Tesseract OCR 실행 경로 (기본 설치 경로와 다를 경우에만 설정)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
