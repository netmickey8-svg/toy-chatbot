# DATA_DIR: 제안서 PDF 폴더 경로 (config.py에서 기본값 설정됨)
# 다른 PC에서 실행 시 아래 줄의 주석을 해제하고 실제 경로로 변경하세요
# DATA_DIR=C:\Users\YourName\Downloads\제안서

# Gemini API Key - https://aistudio.google.com/apikey 에서 발급
GOOGLE_API_KEY=your_api_key_here

# Gemini LLM 모델
GEMINI_MODEL=gemini-2.0-flash

# 임베딩 제공자: openai / local
EMBEDDING_PROVIDER=openai

# OpenAI API Key (임베딩용)
OPENAI_API_KEY=your_openai_key_here

# 임베딩 모델
# - openai 권장: text-embedding-3-small
# - local 권장: BAAI/bge-m3
# EMBEDDING_MODEL=text-embedding-3-small

# OCR 설정 (스캔 PDF 처리용)
OCR_ENABLED=true
OCR_LANG=kor+eng
OCR_MIN_TEXT_CHARS=30

# Tesseract OCR 실행 경로 (기본 설치 경로와 다를 경우에만 설정)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
